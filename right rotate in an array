import java.util.*;
class Main{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        LinkedList<Integer>list=new LinkedList<>();
        for(int i=0;i<n;i++){
            list.add(sc.nextInt());
        }
        int k=sc.nextInt();
        Collections.rotate(list,k);
        for(int i : list){
            System.out.print(i+" ");
        }
    }
}
