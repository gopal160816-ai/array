import java.util.*;
class Main{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int arr[]=new int[n];
        for(int i=0;i<n;i++){
            arr[i]=sc.nextInt();
        
        boolean d=false;
        for(int j=0;j<i;j++){
            if(arr[i]==arr[j]){
                d=true;
                break;
            }
        }
        if(!d){
            System.out.print(arr[i]+" ");
        }
        }
    }
}
