import java.util.*;
class Main{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int arr[]=new int[n-1];
        int sum=0;
        for(int i=1;i<n-1;i++){
            sum+=sc.nextInt();
        }
        int total=n*(n+1)/2;
        System.out.println(total-sum);
    }
}
